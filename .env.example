# DeepSeek API (审图规划)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_API_ENDPOINT=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Coze API (规范查询 + 专家匹配)
COZE_API_TOKEN=your_coze_api_token
COZE_API_ENDPOINT=https://api.coze.cn/v1/workflow/run
COZE_WORKFLOW_CODE_QUERY_ID=your_code_query_workflow_id
COZE_WORKFLOW_EXPERT_MATCH_ID=your_expert_match_workflow_id
COZE_SPACE_ID=your_coze_space_id

# Supabase (创建项目后填写)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
